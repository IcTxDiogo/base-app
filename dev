#!/bin/sh
set -e

# --- Secção de Ajuda ---
show_help() {
    echo "Uso: ./dev <comando> [argumentos]"
    echo ""
    echo "Comandos de Gestão do Ambiente:"
    echo "  up, down, ps, ...      Executa qualquer comando padrão do Docker Compose."
    echo "  reset                  Limpa o estado de setup para forçar a reinstalação no próximo 'up'."
    echo ""
    echo "Ferramentas de Desenvolvimento:"
    echo "  artisan [args]         Executa um comando Artisan no container 'app'."
    echo "  composer [args]        Executa um comando Composer no container 'app'."
    echo "  npm [args]             Executa um comando NPM no container 'node'."
    echo "  php [args]             Executa um comando PHP genérico no container 'app'."
    echo ""
    echo "Suite de Testes Completa:"
    echo "  test                   Roda TODOS os testes: Pest (em paralelo) e depois Dusk."
    echo ""
    echo "Testes de Backend (Pest):"
    echo "  pest-test [pest args]  Roda os testes de backend em PARALELO por padrão."
    echo "  pest-watch [pest args] Roda os testes de backend em modo 'watch' (não paralelo)."
    echo "  pest-coverage [args]   Gera relatório de cobertura para Pest em PARALELO."
    echo ""
    echo "Testes de Browser (Dusk):"
    echo "  dusk-test [dusk args]  Roda os testes de browser com Dusk (não suporta --parallel)."
    echo "  dusk-watch [dusk args] Roda os testes de browser em modo 'watch'."
    echo "  dusk-coverage [args]   Gera relatório de cobertura para Dusk."
    echo ""
    echo "Acesso aos Containers:"
    echo "  bash | shell           Abre um shell no container 'app' como utilizador 'laravel'."
    echo "  node-bash | node-shell Abre um shell no container 'node'."
    echo "  root                   Abre um shell como 'root' no container 'app'."
    echo ""
    echo "  help | -h | --help     Mostra esta mensagem de ajuda."
}

# --- Lógica Principal ---
case "$1" in
artisan)
        shift;
        echo " artisan › php artisan $@"
        docker compose exec app php artisan "$@"
        ;;
    composer|npm|php)
        COMMAND=$1; shift; CONTAINER="app";
        [ "$COMMAND" = "npm" ] && CONTAINER="node";
        echo " $COMMAND › $@"
        docker compose exec "$CONTAINER" "$COMMAND" "$@"
        ;;
    pest-test)
        shift; echo "🧪 Executando testes de backend com Pest (em paralelo)..."; docker compose exec app php artisan test --parallel "$@"
        ;;
    pest-watch)
        shift
        PEST_ARGS="$@"

        if ! command -v inotifywait >/dev/null 2>&1; then
            echo "[!] inotifywait não encontrado. Para usar o modo 'watch', por favor instale com: sudo apt install inotify-tools"
            exit 1
        fi

        run_pest_tests() {
            clear
            echo "[pest-watch] A executar testes com os argumentos: '$PEST_ARGS'..."
            docker compose exec -e COLUMNS=$(tput cols) -T app php artisan test $PEST_ARGS || true
            echo "\n[pest-watch] ✅ Testes concluídos. A aguardar novas alterações... (Ctrl+C para sair)"
        }

        run_pest_tests
        set +e
        while true; do
            inotifywait -r -e modify,create,delete --exclude '(\.git|storage|vendor|\.phpunit\.result\.cache|node_modules)' ./app ./tests >/dev/null 2>&1
            run_pest_tests
        done
        set -e
        ;;
    pest-coverage)
        shift; echo "📊 Gerando relatório de cobertura para Pest (em paralelo)..."; docker compose exec -e XDEBUG_MODE=coverage app php artisan test --parallel --coverage-html public/coverage "$@"; echo "✅ Relatório gerado em 'public/coverage/index.html'."
        ;;
    dusk-test)
        shift; echo "🚗 Executando testes de browser com Dusk..."; docker compose exec app php artisan dusk "$@"
        ;;
    dusk-watch)
        shift; echo "👀 Executando testes de browser com Dusk em modo 'watch'..."; docker compose exec app php artisan dusk --watch "$@"
        ;;
    dusk-coverage)
        shift; echo "📊 Gerando relatório de cobertura para Dusk..."; docker compose exec -e XDEBUG_MODE=coverage app php artisan dusk --coverage-html public/coverage-dusk "$@"; echo "✅ Relatório gerado em 'public/coverage-dusk/index.html'."
        ;;
    test)
        echo "🚀 Executando a suite de testes completa...";
        echo "\n--- Etapa 1: Testes de Backend (Pest) ---";
        ./dev pest-test;
        echo "\n--- Etapa 2: Testes de Browser (Dusk) ---";
        ./dev dusk-test;
        echo "\n✅ Todos os testes foram concluídos com sucesso!"
        ;;
    bash|shell)
        docker compose exec app bash
        ;;
    node-bash|node-shell)
        docker compose exec node bash
        ;;
    root)
        docker compose exec --user root app bash
        ;;
    reset)
        echo "🧹 Limpando o ficheiro de trava do setup..."; docker compose exec app rm -f storage/app/.docker_setup_complete; echo "✅ Pronto! Execute './dev up -d' para forçar uma nova instalação."
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        docker compose "$@" ;;
esac