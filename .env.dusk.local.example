# =================================================================
#      AMBIENTE DE TESTES AUTOMATIZADOS (DUSK) - EXEMPLO
# =================================================================
# Copie este ficheiro para .env.dusk.local

# --- Configuração da Aplicação e URL ---
# A URL base que o Dusk e o Vite usarão dentro do ambiente Docker.
APP_URL=http://nginx
VITE_DEV_SERVER_URL=http://nginx
APP_DEBUG=true
APP_ENV=testing
APP_KEY=

# --- Base de Dados de Teste ---
# Aponta para a base de dados de teste dedicada no container do PostgreSQL.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel_test
DB_USERNAME=postgres
DB_PASSWORD=secret

# --- Broadcasting (Reverb para WebSockets) ---
# Permite testar funcionalidades em tempo real.
BROADCAST_CONNECTION=reverb
REVERB_SERVER_HOST=reverb
REVERB_HOST=nginx
REVERB_PORT=9090
REVERB_SCHEME=http

# Variáveis do Reverb para o Frontend (Vite)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT=80
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Filas, Cache e Sessões (Otimizado para Velocidade e Isolamento) ---
# Usamos drivers em memória/síncronos para tornar os testes rápidos e independentes.
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# --- Redis (Disponível, mas não usado por padrão nos testes) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- E-mail (Captura em Memória) ---
# O driver 'array' impede o envio de emails reais e permite asserções com Mail::assertSent().
MAIL_MAILER=array
MAIL_FROM_ADDRESS="testing@example.com"
MAIL_FROM_NAME="Test App"